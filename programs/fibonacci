memory 1
data 0 "Fibonacci of 10 is: \0"

#include <print_types>

export fib i32 n => i32
  a = "0"
  b = "1"
  i = "0"
  
  block()
    loop()
      
      cond = ge_s(i, n)
      if(cond)
        br 2()
      end()
      
      
      next_val = add(a, b)
      
      
      a = b
      b = next_val
      
      
      i = add(i, "1")
      br 0()
    end()
  end()
  
  return(a)

export main i32 input => i32
  
  printString("0")
  
  ans = fib(input)
  printInt(ans)
  
  return("0")