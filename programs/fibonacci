#include <stdio>

export fib i32 n => i32
  a = "0"
  b = "1"
  i = "0"
  
  loop(){
    cond = lt_s(i, n)
    
    if(cond){
      
      next_val = add(a, b)
      a = b
      b = next_val
      
      
      i = add(i, "1")
      
      
      br 1()
    }
  }
  
  return(a)

export main i32 input => i32
  
  printString('The ')
  printInt(input)
  printString('th fibonacci value is ')

  ans = fib(input)
  printInt(ans)
  printString('.')

  return("0")